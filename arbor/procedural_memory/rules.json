{
  "base_rules": [
    {
      "name": "propose*observe",
      "if": [
        "(I2 ^task <t>)",
        "(S1 ^observed <x> -)"
      ],
      "then": [
        "(S1 ^operator <o> +)",
        "(<o> ^name observe +)"
      ]
    },
    {
      "name": "propose*compare",
      "if": [
        "(S1 ^observed yes)",
        "(S1 ^compared <x> -)"
      ],
      "then": [
        "(S1 ^operator <o> +)",
        "(<o> ^name compare +)"
      ]
    },
    {
      "name": "propose*generalize",
      "if": [
        "(S1 ^compared yes)",
        "(S1 ^schema-ready <x> -)"
      ],
      "then": [
        "(S1 ^operator <o> +)",
        "(<o> ^name generalize +)"
      ]
    },
    {
      "name": "propose*compose",
      "if": [
        "(S1 ^schema-ready yes)",
        "(S1 ^answer-ready <x> -)"
      ],
      "then": [
        "(S1 ^operator <o> +)",
        "(<o> ^name compose +)"
      ]
    },
    {
      "name": "propose*submit",
      "if": [
        "(S1 ^answer-ready yes)",
        "(S1 ^done <x> -)"
      ],
      "then": [
        "(S1 ^operator <o> +)",
        "(<o> ^name submit +)"
      ]
    },
    {
      "name": "apply*observe",
      "if": [
        "(S1 ^operator <o>)",
        "(<o> ^name observe)"
      ],
      "then": [
        "(S1 ^observed yes +)"
      ]
    },
    {
      "name": "apply*compare",
      "if": [
        "(S1 ^operator <o>)",
        "(<o> ^name compare)"
      ],
      "then": [
        "(S1 ^compared yes +)"
      ]
    },
    {
      "name": "apply*generalize",
      "if": [
        "(S1 ^operator <o>)",
        "(<o> ^name generalize)"
      ],
      "then": [
        "(S1 ^schema-ready yes +)"
      ]
    },
    {
      "name": "apply*compose",
      "if": [
        "(S1 ^operator <o>)",
        "(<o> ^name compose)"
      ],
      "then": [
        "(S1 ^answer-ready yes +)"
      ]
    },
    {
      "name": "apply*submit",
      "if": [
        "(S1 ^operator <o>)",
        "(<o> ^name submit)"
      ],
      "then": [
        "(S1 ^done yes +)"
      ]
    }
  ],
  "learned_chunks": []
}